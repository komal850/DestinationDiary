    <% layout("/layouts/boilerplate") %>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>
  .auth-wrap{
    min-height: calc(100vh - 120px);
    font-family: 'Inter', system-ui, sans-serif;
    background: #fdf9f6;
  }
  .auth-card{
    background:#fff;
    border-radius: 24px;
    overflow:hidden;
    box-shadow: 0 30px 80px -30px rgba(220, 80, 60, .25);
  }
  .auth-visual{
    background: linear-gradient(135deg,#ff8a5b 0%,#ff5e84 60%,#e0306c 100%);
    color:#fff; position:relative; overflow:hidden;
    padding:48px;
  }
  .auth-visual::before, .auth-visual::after{
    content:""; position:absolute; border-radius:50%; filter: blur(60px);
  }
  .auth-visual::before{ width:380px;height:380px;background:rgba(255,255,255,.25);top:-120px;left:-120px;}
  .auth-visual::after{ width:420px;height:420px;background:rgba(0,0,0,.15);bottom:-160px;right:-140px;}
  .auth-visual .content{ position:relative; z-index:1; height:100%; display:flex; flex-direction:column; justify-content:space-between;}
  .brand-pill{
    display:inline-flex; align-items:center; gap:10px;
    background: rgba(255,255,255,.18); backdrop-filter: blur(8px);
    padding:10px 16px; border-radius:14px; font-weight:600;
  }
  .brand-pill i{ font-size:1.25rem; }
  .auth-headline{
    font-family:'Playfair Display', serif;
    font-size: 2.4rem; line-height:1.15; font-weight:700;
  }
  .avatars{ display:flex; }
  .avatars span{
    width:34px;height:34px;border-radius:50%;
    border:2px solid #fff; margin-left:-10px;
    display:inline-block;
  }
  .avatars span:first-child{ margin-left:0;}

  .auth-form{ padding: 56px 48px; }
  .auth-form h1{
    font-family:'Playfair Display', serif;
    font-weight:700; font-size:2.25rem; color:#1f1b18;
  }
  .auth-form .lead{ color:#6b6360; font-size:.98rem; }

  .field{ position:relative; }
  .field i.bi{
    position:absolute; left:16px; top:50%; transform:translateY(-50%);
    color:#a39a96;
  }
  .field .form-control{
    border-radius:14px; padding:14px 16px 14px 46px;
    border:1px solid #ece6e2; background:#fff;
    transition: box-shadow .2s, border-color .2s;
  }
  .field .form-control:focus{
    border-color:#ff5e84;
    box-shadow: 0 0 0 4px rgba(255,94,132,.18);
  }
  .toggle-pwd{
    position:absolute; right:10px; top:50%; transform:translateY(-50%);
    background:none; border:0; color:#7a7370; font-size:.85rem; font-weight:500;
    padding:6px 10px; border-radius:8px;
  }
  .toggle-pwd:hover{ color:#1f1b18; background:#f5efeb; }

  .btn-gradient{
    background: linear-gradient(135deg,#ff8a5b,#e0306c);
    color:#fff; border:0; border-radius:14px;
    padding:14px; font-weight:600; width:100%;
    box-shadow: 0 14px 30px -10px rgba(224,48,108,.55);
    transition: transform .15s ease;
  }
  .btn-gradient:hover{ color:#fff; transform: translateY(-1px); }
  .btn-google{
    width:100%; padding:13px; border-radius:14px;
    border:1px solid #ece6e2; background:#fff; font-weight:500;
  }
  .btn-google:hover{ background:#faf5f1; }

  .divider{
    display:flex; align-items:center; gap:14px;
    color:#a39a96; font-size:.78rem; letter-spacing:.18em; text-transform:uppercase;
    margin: 22px 0;
  }
  .divider::before, .divider::after{
    content:""; flex:1; height:1px; background:#ece6e2;
  }
  .text-brand{ color:#e0306c !important; }
  .text-brand:hover{ text-decoration: underline; }

  @media (max-width: 991px){
    .auth-form{ padding: 36px 24px; }
    .auth-card{ border-radius:20px; }
  }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="auth-wrap d-flex align-items-center py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-10 col-xl-9">
        <div class="auth-card row g-0">

          <!-- Visual panel -->
          <div class="col-lg-6 d-none d-lg-block">
            <div class="auth-visual h-100">
              <div class="content">
                <div class="brand-pill">
                  <i class="bi bi-compass"></i> DestinationDiary
                </div>

                <div>
                  <i class="bi bi-airplane fs-3 mb-3 d-block opacity-75"></i>
                  <h2 class="auth-headline">Every trip deserves a beautiful diary.</h2>
                  <p class="mt-3 mb-0" style="opacity:.9;">
                    Pick up where you left off — your saved cities, vibes, and stories are waiting.
                  </p>
                </div>

                <div class="d-flex align-items-center gap-3" style="opacity:.9;">
                  <div class="avatars">
                    <span style="background:#fda4af"></span>
                    <span style="background:#fcd34d"></span>
                    <span style="background:#86efac"></span>
                  </div>
                  <small>Joined by 12,400+ travelers this month</small>
                </div>
              </div>
            </div>
          </div>

          <!-- Form panel -->
          <div class="col-lg-6">
            <div class="auth-form">
              <h1>Welcome back</h1>
              <p class="lead mb-4">Log in to continue your journey.</p>

              <form action="/login" method="post" novalidate>
                <div class="mb-3">
                  <label for="username" class="form-label fw-medium">Username</label>
                  <div class="field">
                    <i class="bi bi-person"></i>
                    <input name="username" id="username" type="text" class="form-control" placeholder="yourname" required>
                  </div>
                </div>

                <div class="mb-2">
                  <div class="d-flex justify-content-between align-items-center">
                    <label for="password" class="form-label fw-medium mb-0">Password</label>
                    <a href="#" class="small text-brand text-decoration-none">Forgot?</a>
                  </div>
                  <div class="field mt-2">
                    <i class="bi bi-lock"></i>
                    <input name="password" id="password" type="password" class="form-control" placeholder="••••••••" required>
                    <button type="button" class="toggle-pwd" onclick="
                      const i=document.getElementById('password');
                      const t=i.type==='password'?'text':'password';
                      i.type=t; this.textContent=t==='password'?'Show':'Hide';
                    ">Show</button>
                  </div>
                </div>


                <button class="btn-gradient" type="submit">
                  Log in <i class="bi bi-arrow-right ms-1"></i>
                </button>

                <p class="text-center mt-4 mb-0 small text-muted">
                  New to DestinationDiary?
                  <a href="/signup" class="text-brand text-decoration-none fw-medium">Create an account</a>
                </p>
              </form>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>
