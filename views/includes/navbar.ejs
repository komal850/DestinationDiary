<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,700;1,500&family=Inter:wght@400;500;600;700&display=swap">

<style>
  :root {
    --dd-ink: #1a1410;
    --dd-muted: #6b6157;
    --dd-paper: #fdfbf7;
    --dd-line: #ece5db;
    --dd-primary: #ff528d;
    --dd-primary-2: #ff7a3d;
    --dd-accent: #f4b740;
  }

  body { font-family: 'Inter', system-ui, sans-serif; color: var(--dd-ink); }

  /* Navbar shell */
  .dd-nav {
    background: rgba(253, 251, 247, 0.95); /* Bumped up opacity slightly to cover underlying content when open */
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid var(--dd-line);
    padding: .65rem 0;
  }

  /* Brand */
  .dd-brand {
    display: inline-flex; align-items: center; gap: .65rem;
    font-family: 'Fraunces', serif;
    font-weight: 600; font-size: 1.4rem; letter-spacing: -0.01em;
    color: var(--dd-ink) !important;
  }
  .dd-brand .dd-logo {
    width: 38px; height: 38px; border-radius: 12px;
    display: grid; place-items: center; color: #fff;
    background: linear-gradient(135deg, var(--dd-primary), var(--dd-primary-2) 60%, var(--dd-accent));
    box-shadow: 0 8px 22px -8px rgba(255, 82, 141, .55);
  }
  .dd-brand em { font-style: italic; color: var(--dd-primary); font-weight: 500; }

  /* Nav links */
  .dd-link {
    position: relative;
    color: var(--dd-muted) !important;
    font-weight: 500; font-size: .94rem;
    padding: .5rem .9rem !important;
    transition: color .2s ease;
  }
  .dd-link:hover { color: var(--dd-ink) !important; }
  
  @media (min-width: 768px) {
    .dd-link::after {
      content: ""; position: absolute; left: 12px; right: 12px; bottom: 4px;
      height: 2px; background: var(--dd-ink);
      transform: scaleX(0); transform-origin: right;
      transition: transform .35s cubic-bezier(.22,1,.36,1);
    }
    .dd-link:hover::after { transform: scaleX(1); transform-origin: left; }
  }

  /* Search */
  .dd-search {
    display: flex; align-items: center;
    background: #fff;
    border: 1px solid var(--dd-line);
    border-radius: 999px;
    padding: 4px 4px 4px 16px;
    box-shadow: 0 1px 2px rgba(26,20,16,.04);
    transition: box-shadow .25s ease, border-color .25s ease;
    width: 100%;
  }
  
  @media (min-width: 768px) {
    .dd-search { min-width: 320px; }
  }

  .dd-search:focus-within {
    border-color: rgba(255, 82, 141, .35);
    box-shadow: 0 8px 24px -10px rgba(255, 82, 141, .35);
  }
  .dd-search .search-inp {
    border: 0; outline: 0; background: transparent;
    padding: .5rem .25rem; font-size: .92rem; flex: 1; min-width: 0;
  }
  .dd-search .search-inp:focus { box-shadow: none; border: none; }
  
  .btn-search {
    background: linear-gradient(135deg, var(--dd-primary), var(--dd-primary-2));
    color: #fff; border: 0;
    border-radius: 999px;
    padding: .55rem 1.1rem;
    font-weight: 600; font-size: .88rem;
    display: inline-flex; align-items: center; gap: .4rem;
    transition: transform .2s ease, box-shadow .2s ease, filter .2s ease;
    white-space: nowrap;
  }
  .btn-search:hover {
    color: #fff; filter: brightness(1.05);
    transform: translateY(-1px);
    box-shadow: 0 10px 22px -10px rgba(255, 82, 141, .6);
  }

  /* Right side CTAs */
  .dd-list-link {
    color: var(--dd-ink) !important;
    font-weight: 600; font-size: .9rem;
    padding: .5rem .9rem !important;
    border-radius: 999px;
    transition: background-color .2s ease;
  }
  .dd-list-link:hover { background: #f3ece1; }

  .dd-cta {
    background: var(--dd-ink); color: #fff !important;
    border-radius: 999px; padding: .55rem 1.15rem !important;
    font-weight: 600; font-size: .9rem;
    transition: transform .2s ease, background-color .2s ease;
    display: inline-block;
    text-align: center;
  }
  .dd-cta:hover { background: #000; transform: translateY(-1px); color: #fff !important; }

  .dd-ghost {
    color: var(--dd-muted) !important;
    font-weight: 500; font-size: .9rem;
    padding: .5rem .8rem !important;
    transition: color .2s ease;
    display: inline-block;
    text-align: center;
  }
  .dd-ghost:hover { color: var(--dd-ink) !important; }

  .dd-divider {
    width: 1px; height: 24px; background: var(--dd-line);
    margin: 0 .5rem; align-self: center;
  }

  /* Toggler Button styling */
  .navbar-toggler {
    border: 1px solid var(--dd-line);
    border-radius: 12px; padding: .35rem .55rem;
  }
  .navbar-toggler:focus { box-shadow: 0 0 0 3px rgba(255,82,141,.18); }

  /* Mobile Layout Structural Adjustments */
  @media (max-width: 767.98px) {
    .navbar-collapse {
      background-color: var(--dd-paper);
      padding: 1rem 0.5rem;
      border-radius: 12px;
      margin-top: 0.5rem;
      border: 1px solid var(--dd-line);
      box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
    .dd-divider { display: none !important; }
    .navbar-nav { gap: 0.5rem; }
    .dd-auth-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: 0.5rem;
      padding-top: 0.75rem;
      border-top: 1px solid var(--dd-line);
    }
  }
</style>

<nav class="navbar navbar-expand-md dd-nav sticky-top">
  <div class="container-fluid px-3 px-lg-4">

    <a class="navbar-brand dd-brand" href="/">
      <span class="dd-logo"><i class="fa-solid fa-compass"></i></span>
      <em>DestinationDiary</em>
    </a>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">

      <div class="navbar-nav me-auto">
        <a class="nav-link dd-link" href="/listings">Explore</a>
      </div>

      <form action="/listings" method="GET" class="mx-auto my-2 my-md-0 w-100" style="max-width: 400px;">
        <div class="dd-search">
          <i class="fa-solid fa-magnifying-glass text-muted"></i>
          <input
            name="search"
            class="form-control search-inp ms-2"
            type="text"
            placeholder="Search a city or vibe…"
          >
          <button class="btn btn-search" type="submit">
            <i class="fa-solid fa-arrow-right d-md-none"></i>
            <span class="d-none d-md-inline">Search</span>
          </button>
        </div>
      </form>

      <div class="navbar-nav ms-auto align-items-md-center">
        <a class="nav-link dd-list-link mb-2 mb-md-0" href="/listings/new">
          <i class="fa-regular fa-pen-to-square me-1"></i> List your diary
        </a>

        <span class="dd-divider d-none d-md-block"></span>

        <div class="dd-auth-group">
          <% if(!currUser) { %>
            <a class="nav-link dd-ghost" href="/login">Log in</a>
            <a class="nav-link dd-cta" href="/signup">Sign up</a>
          <% } %>

          <% if(currUser) { %>
            <a class="nav-link dd-cta" href="/logout">Log out</a>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</nav>